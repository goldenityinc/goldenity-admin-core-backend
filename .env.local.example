# Catatan:
# Aplikasi backend ini membaca file `.env`.
# Untuk local run, copy file ini menjadi `.env` lalu isi nilainya.

PORT=5000
NODE_ENV=development

# Wajib untuk boot backend + Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goldenity_admin?schema=public

# Wajib karena Firebase Admin diinisialisasi saat startup.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Wajib untuk internal JWT auth.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# Disarankan untuk akses dari frontend lokal.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional, tetapi dipakai di production untuk integrasi ERP.
# Isi jika ingin mencoba provisioning ERP / feature sync.
ERP_API_URL=
ERP_API_BASE_URL=
ERP_WEB_ORIGIN=
ERP_MASTER_EMAIL=
ERP_MASTER_PASSWORD=
ERP_MASTER_ACCESS_TOKEN=
ERP_API_TIMEOUT_MS=15000

# Optional origin web untuk solusi non-POS saat tombol "Open App" dibangun dari backend.
SCHOOL_ERP_WEB_ORIGIN=
CLINIC_WEB_ORIGIN=
POS_WEB_ORIGIN=

# Optional, tetapi dipakai di production untuk upload logo/media.
# Isi jika ingin menguji upload tenant logo atau expense attachment.
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=

# Alias lain yang juga dibaca codebase. Pilih salah satu grup saja.
AWS_ENDPOINT_URL=
AWS_REGION=auto
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
R2_BUCKET=

# Optional, dipakai untuk internal bridge accounting / service-to-service auth.
ADMIN_CORE_INTERNAL_TOKEN=
