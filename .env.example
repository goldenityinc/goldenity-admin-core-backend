# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/goldenity_admin?schema=public"

# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key\n-----END PRIVATE KEY-----\n"

# CORS Configuration (Optional)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ERP Integration (Optional)
# Base URL for ERP API (must include /api/v1)
ERP_API_BASE_URL=http://localhost:3002/api/v1
ERP_API_TIMEOUT_MS=15000
