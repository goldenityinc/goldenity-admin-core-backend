# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/goldenity_admin?schema=public"

# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key\n-----END PRIVATE KEY-----\n"

# CORS Configuration (Optional)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ERP Integration (Optional)
# Base URL for ERP API (must include /api/v1)
## ERP Integration
# Base URL of ERP API. You can provide the origin only; backend will normalize to include /api/v1.
# Example:
# ERP_API_URL=https://erpapi-production-xxxx.up.railway.app
# or:
# ERP_API_BASE_URL=https://erpapi-production-xxxx.up.railway.app/api/v1
ERP_API_URL=
ERP_API_BASE_URL=http://localhost:3002/api/v1

# ERP master admin credential used for provisioning + feature catalog.
# Prefer setting these only in Railway Variables (production), not in code.
ERP_MASTER_EMAIL=
ERP_MASTER_PASSWORD=
# Optional: if you already have a valid ERP access token (short-lived), you can set it here.
ERP_MASTER_ACCESS_TOKEN=
ERP_API_TIMEOUT_MS=15000

# S3-Compatible Object Storage (Railway)
# Required for tenant logo upload/download and other media assets.
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Optional: public base URL for CDN/proxy if different from STORAGE_ENDPOINT.
STORAGE_PUBLIC_BASE_URL=

# Internal service auth for bridge -> admin-core accounting auto-post.
ADMIN_CORE_INTERNAL_TOKEN=
