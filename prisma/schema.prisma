generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String        @id @default(uuid())
  name          String
  slug          String        @unique
  email         String?       @unique
  phone         String?
  address       String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  city          String?
  country       String?
  bridgeApiUrl  String?       @map("bridge_api_url")
  logoUrl       String?       @map("logo_url")
  logoObjectKey String?       @map("logo_object_key")
  showInventoryImages Boolean  @default(true) @map("show_inventory_images")
  appInstances  AppInstance[]
  branches      Branch[]
  users         User[]

  @@index([slug])
  @@map("tenants")
}

model Branch {
  id                 BigInt          @id @default(autoincrement())
  tenantId           String          @map("tenant_id")
  name               String
  branchCode         String?         @unique @map("branch_code")
  address            String?
  phone              String?
  isActive           Boolean         @default(true) @map("is_active")
  isMainBranch       Boolean         @default(false) @map("is_main_branch")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at")
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users              User[]
  salesRecords       sales_records[] @relation("SalesRecordBranch")
  pickupSalesRecords sales_records[] @relation("SalesRecordTargetPickupBranch")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("branches")
}

model User {
  id           String          @id @default(uuid())
  firebaseUid  String?         @unique
  email        String?         @unique
  name         String
  role         UserRole        @default(CRM_STAFF)
  tenantId     String
  branchId     BigInt?         @map("branch_id")
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  passwordHash String?
  username     String?
  customRoleId String?         @map("custom_role_id")
  appAccesses  UserAppAccess[]
  branch       Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([tenantId])
  @@index([email])
  @@index([firebaseUid])
  @@index([username])
  @@map("users")
}

/// Custom role definition per-tenant untuk Dynamic RBAC.
/// permissions berformat JSON: { "penjualan": {"c":true,"r":true,"u":false,"d":false}, ... }
model CustomRole {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  permissions Json
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isDefault], map: "idx_custom_roles_is_default")
  @@index([tenantId], map: "idx_custom_roles_tenant_id")
  @@map("custom_roles")
}

model Solution {
  id           String        @id @default(uuid())
  name         String
  code         String        @unique
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appInstances AppInstance[]

  @@index([code])
  @@map("solutions")
}

model AppInstance {
  id                 String              @id @default(uuid())
  tenantId           String
  solutionId         String
  tier               SubscriptionTier
  status             AppInstanceStatus   @default(ACTIVE)
  dbConnectionString String?
  appUrl             String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  endDate            DateTime?           @map("end_date")
  syncMode           SyncMode            @default(CLOUD_FIRST) @map("sync_mode")
  addons             String[]            @default([])
  modules            AppInstanceModule[]
  solution           Solution            @relation(fields: [solutionId], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userAccesses       UserAppAccess[]

  @@unique([tenantId, solutionId])
  @@index([tenantId])
  @@index([solutionId])
  @@index([status])
  @@map("app_instances")
}

model ModuleDefinition {
  id                 String                 @id @default(uuid())
  moduleKey          String                 @unique @map("module_key")
  displayName        String                 @map("display_name")
  category           String
  description        String?
  isCore             Boolean                @default(false) @map("is_core")
  status             ModuleDefinitionStatus @default(ACTIVE)
  dependencies       String[]               @default([])
  defaultConfig      Json?                  @map("default_config")
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @default(now()) @updatedAt
  appInstanceModules AppInstanceModule[]

  @@index([category])
  @@index([status])
  @@map("module_definitions")
}

model AppInstanceModule {
  id                 String                 @id @default(uuid())
  appInstanceId      String                 @map("app_instance_id")
  moduleDefinitionId String                 @map("module_definition_id")
  isEnabled          Boolean                @default(true) @map("is_enabled")
  source             ModuleAssignmentSource @default(MANUAL_OVERRIDE)
  billingStatus      String?                @map("billing_status")
  activatedAt        DateTime?              @map("activated_at")
  expiredAt          DateTime?              @map("expired_at")
  config             Json?
  limits             Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @default(now()) @updatedAt
  appInstance        AppInstance            @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)
  moduleDefinition   ModuleDefinition       @relation(fields: [moduleDefinitionId], references: [id])

  @@unique([appInstanceId, moduleDefinitionId])
  @@index([appInstanceId])
  @@index([moduleDefinitionId])
  @@index([isEnabled])
  @@index([source])
  @@map("app_instance_modules")
}

model UserAppAccess {
  id            String      @id @default(uuid())
  userId        String
  appInstanceId String
  role          AppRole     @default(STAFF)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appInstance   AppInstance @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appInstanceId])
  @@index([appInstanceId])
  @@map("user_app_accesses")
}

model app_users {
  id             BigInt    @id @default(autoincrement())
  tenant_id      String?
  username       String
  password       String?
  name           String?
  role           String?
  custom_role_id String?
  is_active      Boolean?  @default(true)
  created_at     DateTime? @default(now())
  updated_at     DateTime? @default(now())

  @@index([tenant_id])
  @@index([username])
}

model categories {
  id            BigInt    @id @default(autoincrement())
  tenant_id     String?
  name          String
  created_at    DateTime? @default(now())
  updated_at    DateTime? @default(now())
  category_type String    @default("PRODUCT")

  @@index([tenant_id])
}

model customers {
  id          Int       @id @default(autoincrement())
  tenant_id   String?
  name        String
  phone       String?
  total_spent Float?    @default(0)
  created_at  DateTime? @default(now())
  updated_at  DateTime? @default(now())

  @@index([tenant_id])
}

model daily_cash {
  id         BigInt    @id @default(autoincrement())
  tenant_id  String?
  amount     Decimal?  @db.Decimal
  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  @@index([tenant_id])
}

model expenses {
  id          BigInt    @id @default(autoincrement())
  tenant_id   String?
  amount      Decimal?  @db.Decimal
  notes       String?
  created_at  DateTime? @default(now())
  updated_at  DateTime? @default(now())
  status      String?
  void_reason String?
  voided_at   DateTime? @db.Timestamptz(6)

  @@index([tenant_id])
}

model kas_bon {
  id         BigInt    @id @default(autoincrement())
  tenant_id  String?
  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  @@index([tenant_id])
}

model kas_bon_payment_history {
  id                BigInt    @id @default(autoincrement())
  sales_record_id   BigInt
  paid_amount       Decimal   @db.Decimal(14, 2)
  previous_balance  Decimal   @db.Decimal(14, 2)
  remaining_balance Decimal   @db.Decimal(14, 2)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  tenant_id         String?
  payment_method    String?
  paid_at           DateTime? @default(now()) @db.Timestamptz(6)
  note              String?

  @@index([sales_record_id], map: "idx_kas_bon_payment_history_sales_record_id")
  @@index([tenant_id], map: "idx_kas_bon_payment_history_tenant_id")
}

model order_history {
  id             BigInt    @id @default(autoincrement())
  tenant_id      String?
  supplier_name  String
  supplier_phone String?
  message_body   String?
  created_at     DateTime? @default(now())

  @@index([tenant_id])
}

model order_history_items {
  id                      BigInt    @id @default(autoincrement())
  tenant_id               String?
  order_history_id        BigInt?
  is_manual               Boolean?  @default(false)
  product_id              BigInt?
  manual_item_id          BigInt?
  item_name               String
  qty                     Int?      @default(1)
  notes                   String?
  supplier_name           String?
  ordered_at              DateTime? @default(now())
  is_archived             Boolean?  @default(false)
  is_received             Boolean?  @default(false)
  received_at             DateTime?
  received_qty            Int?
  received_purchase_price Int?
  created_at              DateTime? @default(now())

  @@index([order_history_id])
  @@index([tenant_id])
}

model petty_cash_logs {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String?
  user_id    String?
  amount     Int?
  type       String?
  notes      String?
  created_at DateTime? @default(now())
  user_name  String?

  @@index([created_at(sort: Desc)], map: "idx_petty_cash_logs_created_at")
  @@index([tenant_id, created_at(sort: Desc)], map: "idx_petty_cash_logs_tenant_created_at")
  @@index([tenant_id, created_at])
  @@index([tenant_id])
  @@index([user_id])
}

model products {
  id             String    @id
  tenant_id      String?
  name           String
  barcode        String?
  category       String?
  price          Float?    @default(0)
  purchase_price Float?
  stock          Int?      @default(0)
  is_service     Boolean?  @default(false)
  supplier_name  String?
  image_url      String?
  is_active      Boolean?  @default(true)
  created_at     DateTime? @default(now())
  updated_at     DateTime? @default(now())
  reference_id   String?

  @@index([tenant_id])
}

model restock_history {
  id         BigInt    @id @default(autoincrement())
  tenant_id  String?
  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  @@index([tenant_id])
}

model sales_record_items {
  id              BigInt    @id @default(autoincrement())
  tenant_id       String?
  sales_record_id BigInt
  product_id      String?
  product_name    String?
  qty             Int       @default(1)
  custom_price    Decimal?  @db.Decimal(14, 2)
  note            String?
  is_service      Boolean   @default(false)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
  is_custom_item  Boolean   @default(false)
  custom_name     String?

  @@index([sales_record_id], map: "idx_sales_record_items_sales_record_id")
  @@index([tenant_id], map: "idx_sales_record_items_tenant_id")
}

model sales_records {
  id                      BigInt      @id @default(autoincrement())
  tenant_id               String?
  reference_id            String?
  payment_method          String?
  payment_type            String?
  total_price             Decimal?    @db.Decimal
  total_amount            Decimal?    @db.Decimal
  remaining_balance       Decimal?    @db.Decimal
  outstanding_balance     Decimal?    @db.Decimal
  created_at              DateTime?   @default(now())
  updated_at              DateTime?   @default(now())
  receipt_number          String?
  cashier_id              String?
  cashier_name            String?
  payment_status          String?
  items_json              Json?
  customer_name           String?
  total_discount          BigInt?
  total_tax               BigInt?
  total_profit            BigInt?
  amount_paid             Decimal?    @default(0) @db.Decimal
  branch_id               BigInt?
  order_type              OrderType   @default(WALK_IN)
  order_status            OrderStatus @default(COMPLETED)
  pickup_date             DateTime?
  target_pickup_branch_id BigInt?
  branch                  Branch?     @relation("SalesRecordBranch", fields: [branch_id], references: [id])
  target_pickup_branch    Branch?     @relation("SalesRecordTargetPickupBranch", fields: [target_pickup_branch_id], references: [id])

  @@index([branch_id])
  @@index([target_pickup_branch_id])
  @@index([order_type])
  @@index([order_status])
  @@index([reference_id])
  @@index([tenant_id])
}

model service_orders {
  id               String   @id
  tenant_id        String
  customer_name    String
  customer_phone   String?
  device_type      String
  device_brand     String?
  serial_number    String?
  complaint        String
  status           String   @default("PENDING")
  estimated_cost   Decimal? @db.Decimal(14, 2)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())
  technician_notes String?
  service_details  Json?

  @@index([created_at(sort: Desc)], map: "idx_service_orders_created_at")
  @@index([tenant_id], map: "idx_service_orders_tenant_id")
  @@index([tenant_id, status], map: "idx_service_orders_tenant_status")
  @@index([created_at])
  @@index([tenant_id])
  @@index([tenant_id, status])
}

model store_settings {
  id         BigInt    @id @default(autoincrement())
  tenant_id  String?
  key        String?
  value      String?
  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  @@index([tenant_id])
}

model suppliers {
  id         BigInt    @id @default(autoincrement())
  tenant_id  String?
  name       String
  phone      String?
  address    String?
  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  @@index([tenant_id])
}

model transactions {
  id         BigInt    @id @default(autoincrement())
  tenant_id  String?
  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  @@index([tenant_id])
}

model AccountCategory {
  id          String              @id @default(uuid())
  code        AccountCategoryType @unique
  name        String
  description String?
  sortOrder   Int                 @default(0) @map("sort_order")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  accounts    ChartOfAccount[]

  @@map("account_categories")
}

model ChartOfAccount {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  accountCategoryId String               @map("account_category_id")
  code              String
  name              String
  description       String?
  normalBalance     AccountNormalBalance @map("normal_balance")
  isSystem          Boolean              @default(false) @map("is_system")
  isActive          Boolean              @default(true) @map("is_active")
  parentAccountId   String?              @map("parent_account_id")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  category          AccountCategory      @relation(fields: [accountCategoryId], references: [id])
  parentAccount     ChartOfAccount?      @relation("ChartOfAccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts     ChartOfAccount[]     @relation("ChartOfAccountHierarchy")
  journalLines      JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([accountCategoryId])
  @@index([parentAccountId])
  @@index([isActive])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id              String                 @id @default(uuid())
  tenantId        String                 @map("tenant_id")
  entryNumber     String                 @map("entry_number")
  entryDate       DateTime               @map("entry_date")
  sourceType      JournalEntrySourceType @default(MANUAL) @map("source_type")
  referenceId     String?                @map("reference_id")
  referenceNumber String?                @map("reference_number")
  description     String?
  totalDebit      Decimal                @map("total_debit") @db.Decimal(18, 2)
  totalCredit     Decimal                @map("total_credit") @db.Decimal(18, 2)
  isPosted        Boolean                @default(true) @map("is_posted")
  createdByUserId String?                @map("created_by_user_id")
  postedAt        DateTime?              @map("posted_at")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  lines           JournalLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId, entryDate])
  @@index([sourceType, referenceId])
  @@index([createdByUserId])
  @@map("journal_entries")
}

model JournalLine {
  id               String         @id @default(uuid())
  journalEntryId   String         @map("journal_entry_id")
  chartOfAccountId String         @map("chart_of_account_id")
  lineNumber       Int            @map("line_number")
  description      String?
  debit            Decimal        @default(0) @db.Decimal(18, 2)
  credit           Decimal        @default(0) @db.Decimal(18, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  account          ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])
  journalEntry     JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@unique([journalEntryId, lineNumber])
  @@index([journalEntryId])
  @@index([chartOfAccountId])
  @@map("journal_lines")
}

enum AccountCategoryType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountNormalBalance {
  DEBIT
  CREDIT
}

enum JournalEntrySourceType {
  POS_SALE
  EXPENSE
  MANUAL
  ADJUSTMENT
  OPENING_BALANCE
}

enum OrderType {
  WALK_IN
  PRE_ORDER
  DELIVERY
}

enum OrderStatus {
  PENDING
  PREPARING
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  CRM_MANAGER
  CRM_STAFF
  READ_ONLY
}

enum SubscriptionTier {
  Standard
  Professional
  Enterprise
  Custom
}

enum AppInstanceStatus {
  ACTIVE
  SUSPENDED
}

enum AppRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum ModuleDefinitionStatus {
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum ModuleAssignmentSource {
  CORE
  BUNDLE
  ADDON
  TRIAL
  MANUAL_OVERRIDE
}

enum SyncMode {
  CLOUD_FIRST
  LOCAL_FIRST
  LOCAL_SERVER
}
