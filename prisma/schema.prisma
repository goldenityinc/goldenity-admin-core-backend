// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model Tenant: Menyimpan data klien/perusahaan
model Tenant {
  id          String   @id @default(uuid())
  name        String   // Nama perusahaan/klien
  slug        String   @unique // URL-friendly identifier (contoh: "toko-jaya")
  email       String?  @unique
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi
  users       User[]
  products    Product[]

  @@index([slug])
  @@map("tenants")
}

// Model User: Menyimpan data kasir/admin yang berelasi dengan Tenant
model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique // Firebase UID dari Firebase Auth
  email       String   @unique
  name        String
  role        UserRole @default(CASHIER) // SUPER_ADMIN, TENANT_ADMIN, CASHIER
  
  // Multi-Tenant: Setiap user harus terikat dengan satu tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firebaseUid])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// Enum untuk role user
enum UserRole {
  SUPER_ADMIN   // Akses ke semua tenant (untuk internal Goldenity)
  TENANT_ADMIN  // Admin dari satu tenant tertentu
  CASHIER       // Kasir dari satu tenant tertentu
}

// Model Product: Menyimpan data barang, wajib memiliki relasi tenantId
model Product {
  id          String   @id @default(uuid())
  sku         String   // Stock Keeping Unit
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  stock       Int      @default(0)
  category    String?
  imageUrl    String?
  
  // Multi-Tenant: Setiap product harus terikat dengan satu tenant
  // Ini mencegah data product bocor/tercampur antar klien
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, sku]) // SKU harus unique per tenant
  @@index([tenantId])
  @@index([sku])
  @@map("products")
}
