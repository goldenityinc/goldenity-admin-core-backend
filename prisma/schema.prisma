generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String        @id @default(uuid())
  name           String
  slug           String        @unique
  bridgeApiUrl   String?       @map("bridge_api_url")
  showInventoryImages Boolean   @default(true) @map("show_inventory_images")
  email          String?       @unique
  phone          String?
  address        String?
  logoUrl        String?       @map("logo_url")
  logoObjectKey  String?       @map("logo_object_key")
  city           String?
  country        String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users          User[]
  appInstances   AppInstance[]
  customRoles    CustomRole[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id             String          @id @default(uuid())
  firebaseUid    String?         @unique
  username       String?
  passwordHash   String?
  email          String?         @unique
  name           String
  role           UserRole        @default(CRM_STAFF)
  customRoleId   String?         @map("custom_role_id")
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole     CustomRole?     @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  appAccesses    UserAppAccess[]

  @@index([firebaseUid])
  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@unique([tenantId, username])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  CRM_MANAGER
  CRM_STAFF
  READ_ONLY
}

/// Custom role definition per-tenant untuk Dynamic RBAC.
/// permissions berformat JSON: { "penjualan": {"c":true,"r":true,"u":false,"d":false}, ... }
model CustomRole {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  description  String?
  isDefault    Boolean  @default(false) @map("is_default")
  permissions  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("custom_roles")
}

model Solution {
  id             String        @id @default(uuid())
  name           String
  code           String        @unique
  description    String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appInstances   AppInstance[]

  @@index([code])
  @@map("solutions")
}

model AppInstance {
  id                   String             @id @default(uuid())
  tenantId             String
  solutionId           String
  tier                 SubscriptionTier
  addons               String[]           @default([])
  syncMode             SyncMode           @default(CLOUD_FIRST) @map("sync_mode")
  status               AppInstanceStatus  @default(ACTIVE)
  dbConnectionString   String?
  appUrl               String?
  endDate              DateTime?          @map("end_date")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  solution             Solution           @relation(fields: [solutionId], references: [id], onDelete: Restrict)
  userAccesses         UserAppAccess[]
  modules              AppInstanceModule[]

  @@unique([tenantId, solutionId])
  @@index([tenantId])
  @@index([solutionId])
  @@index([status])
  @@map("app_instances")
}

model ModuleDefinition {
  id                String                 @id @default(uuid())
  moduleKey         String                 @unique @map("module_key")
  displayName       String                 @map("display_name")
  category          String
  description       String?
  isCore            Boolean                @default(false) @map("is_core")
  status            ModuleDefinitionStatus @default(ACTIVE)
  dependencies      String[]               @default([])
  defaultConfig     Json?                  @map("default_config")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  appInstanceModules AppInstanceModule[]

  @@index([category])
  @@index([status])
  @@map("module_definitions")
}

model AppInstanceModule {
  id                 String                    @id @default(uuid())
  appInstanceId      String                    @map("app_instance_id")
  moduleDefinitionId String                    @map("module_definition_id")
  isEnabled          Boolean                   @default(true) @map("is_enabled")
  source             ModuleAssignmentSource    @default(MANUAL_OVERRIDE)
  billingStatus      String?                   @map("billing_status")
  activatedAt        DateTime?                 @map("activated_at")
  expiredAt          DateTime?                 @map("expired_at")
  config             Json?
  limits             Json?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  appInstance        AppInstance               @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)
  moduleDefinition   ModuleDefinition          @relation(fields: [moduleDefinitionId], references: [id], onDelete: Restrict)

  @@unique([appInstanceId, moduleDefinitionId])
  @@index([appInstanceId])
  @@index([moduleDefinitionId])
  @@index([isEnabled])
  @@index([source])
  @@map("app_instance_modules")
}

model UserAppAccess {
  id              String      @id @default(uuid())
  userId          String
  appInstanceId   String
  role            AppRole     @default(STAFF)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  appInstance     AppInstance @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)

  @@unique([userId, appInstanceId])
  @@index([appInstanceId])
  @@map("user_app_accesses")
}

enum SubscriptionTier {
  Standard
  Professional
  Enterprise
  Custom
}

enum AppInstanceStatus {
  ACTIVE
  SUSPENDED
}

enum AppRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum ModuleDefinitionStatus {
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum ModuleAssignmentSource {
  CORE
  BUNDLE
  ADDON
  TRIAL
  MANUAL_OVERRIDE
}

enum SyncMode {
  CLOUD_FIRST
  LOCAL_FIRST
  LOCAL_SERVER
}
