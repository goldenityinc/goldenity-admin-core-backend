generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id             String        @id @default(uuid())
  name           String
  slug           String        @unique
  bridgeApiUrl   String?       @map("bridge_api_url")
  showInventoryImages Boolean   @default(true) @map("show_inventory_images")
  email          String?       @unique
  phone          String?
  address        String?
  logoUrl        String?       @map("logo_url")
  logoObjectKey  String?       @map("logo_object_key")
  city           String?
  country        String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users          User[]
  appInstances   AppInstance[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id             String          @id @default(uuid())
  firebaseUid    String?         @unique
  username       String?
  passwordHash   String?
  email          String?         @unique
  name           String
  role           UserRole        @default(CRM_STAFF)
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  appAccesses    UserAppAccess[]

  @@index([firebaseUid])
  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@unique([tenantId, username])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  CRM_MANAGER
  CRM_STAFF
  READ_ONLY
}

model Solution {
  id             String        @id @default(uuid())
  name           String
  code           String        @unique
  description    String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appInstances   AppInstance[]

  @@index([code])
  @@map("solutions")
}

model AppInstance {
  id                   String             @id @default(uuid())
  tenantId             String
  solutionId           String
  tier                 SubscriptionTier
  syncMode             SyncMode           @default(CLOUD_FIRST) @map("sync_mode")
  status               AppInstanceStatus  @default(ACTIVE)
  dbConnectionString   String?
  appUrl               String?
  endDate              DateTime?          @map("end_date")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  solution             Solution           @relation(fields: [solutionId], references: [id], onDelete: Restrict)
  userAccesses         UserAppAccess[]

  @@unique([tenantId, solutionId])
  @@index([tenantId])
  @@index([solutionId])
  @@index([status])
  @@map("app_instances")
}

model UserAppAccess {
  id              String      @id @default(uuid())
  userId          String
  appInstanceId   String
  role            AppRole     @default(STAFF)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  appInstance     AppInstance @relation(fields: [appInstanceId], references: [id], onDelete: Cascade)

  @@unique([userId, appInstanceId])
  @@index([appInstanceId])
  @@map("user_app_accesses")
}

enum SubscriptionTier {
  Standard
  Professional
  Enterprise
  Custom
}

enum AppInstanceStatus {
  ACTIVE
  SUSPENDED
}

enum AppRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum SyncMode {
  CLOUD_FIRST
  LOCAL_FIRST
  LOCAL_SERVER
}
